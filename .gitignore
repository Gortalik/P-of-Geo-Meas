```gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Build and distribution
dist/
build/
*.egg-info/

# Virtual environments
venv/
.venv/
.env
.env.local
*.env.*

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo

# Logs and temporary files
*.log
*.tmp
*.temp

# Coverage reports
.coverage
coverage/
htmlcov/

# OS specific
.DS_Store
Thumbs.db
```