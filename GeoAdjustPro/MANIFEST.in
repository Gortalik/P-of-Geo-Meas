# MANIFEST.in - Файл для включения ресурсов в пакет
# Используется при сборке пакета через setuptools

# Основные файлы проекта
include VERSION
include README.md
include LICENSE
include requirements.txt

# Рекурсивное включение ресурсов
recursive-include src/geoadjust/gui/resources *
recursive-include src/geoadjust/crs/database *.yaml
recursive-include src/geoadjust/resources *

# Исключение ненужных файлов
prune tests
prune docs
prune build
prune dist
prune *.egg-info
prune __pycache__
prune .git
prune .github
prune venv
prune env
prune ENV

# Исключение временных файлов
global-exclude *.pyc
global-exclude *.pyo
global-exclude *.log
global-exclude *~
global-exclude .DS_Store
global-exclude Thumbs.db
